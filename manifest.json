{
  "manifest_version": 3,
  "name": "Salesforce Lightning Admin Enhancer",
  "description": "Salesforce Admin Enhancer for Lightning",
  "version": "2.1.6",

  "icons": {
    "16": "lightning_stylized_icon__1__icon.png",
    "48": "lightning_stylized_icon__1__icon.png",
    "128": "lightning_stylized_icon__1__icon.png"
  },

  "background": {
    "service_worker": "src/background.js"
  },

  "permissions": ["storage", "cookies"],

  "host_permissions": [
    "*://*.lightning.force.com/*",
    "*://*.my.salesforce.com/*",
    "*://*.salesforce.com/ui/setup/export/*",
    "*://*.my.salesforce-setup.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.lightning.force.com/*",
        "*://*.salesforce.com/ui/setup/export/*",
        "*://*.my.salesforce-setup.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/features/*.js", "src/utils/*.js"],
      "matches": [
        "https://*.lightning.force.com/*",
        "https://*.salesforce.com/*",
        "https://*.my.salesforce-setup.com/*"
      ]
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
